DISCORD_TOKEN=COLE_O_TOKEN_DO_BOT_AQUI
DISCORD_CHANNEL_ID=1511957022860382288
PREFIX=!
RCON_HOST=niceatm11.jogar.io
RCON_PORT=25575
RCON_PASSWORD=COLE_SENHA_RCON_AQUI
TOP_LIMIT=10

# Opcional: texto do comando !evento
EVENTO_TITULO=🎉 Evento valendo VIP
EVENTO_DATA=Final de semana
EVENTO_PREMIO=VIP para o vencedor
EVENTO_TEXTO=No próximo final de semana teremos evento valendo VIP. Mais detalhes serão anunciados em breve.

# Compra VIP automática com Mercado Pago
MP_ACCESS_TOKEN=COLE_SEU_ACCESS_TOKEN_DO_MERCADO_PAGO_AQUI

# URL pública do Railway. Exemplo: https://seu-projeto.up.railway.app
PUBLIC_URL=

# Canal separado onde o player usa !comprarvip / onde fica o painel VIP
VIP_PANEL_CHANNEL_ID=

# Categoria opcional onde o bot criará salas privadas de compra
VIP_CATEGORY_ID=

# Canal opcional de log para avisar Staff sobre pagamentos/VIPs entregues
VIP_LOG_CHANNEL_ID=

# Cargo opcional de Staff autorizado a criar painel VIP
VIP_STAFF_ROLE_ID=

# Opcional: e-mail válido usado no campo payer.email do Mercado Pago.
# Se deixar vazio, o bot usa um e-mail técnico automático com domínio gmail.com.
MP_PAYER_EMAIL=

# Verificador automático de pagamento pendente pelo Mercado Pago.
MP_POLL_INTERVAL_SECONDS=20

# IMPORTANTE:
# PUBLIC_URL precisa ser o domínio público HTTPS do Railway.
# Certo: PUBLIC_URL=https://seu-projeto.up.railway.app
# Errado: PUBLIC_URL=seu-projeto.up.railway.app/webhook/mercadopago
# Errado: PUBLIC_URL=RAILWAY_PRIVATE_DOMAIN ou domínio .internal

# Integração atual da Loja ATM11:
# - O bot adiciona Pontos VIP no objetivo vip_pontos.
# - A loja do jogo abre com /loja.
# - O tempo da recompensa online aparece com /recompensa.
# - Os valores da recompensa por VIP ficam no FTB Ranks pelo node atm11shop.reward_points.
